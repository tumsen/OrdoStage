{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "_build": "v3",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "studio": "cloud-studio --port 3001 --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:prepare": "docker compose up -d && sleep 3 && prisma migrate deploy",
    "db:migrate:railway": "bunx @railway/cli run -- bunx prisma migrate deploy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@hono/node-server": "1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "6",
    "@vibecodeapp/backend-sdk": "^1.0.1",
    "@vibecodeapp/cloud-studio": "^0.2.4",
    "@vibecodeapp/proxy": "^2.0.3",
    "better-auth": "^1.6.4",
    "hono": "4.6.0",
    "pdf-lib": "^1.17.1",
    "prisma": "6",
    "resend": "^6.12.0",
    "zod": "^4.3.0"
  }
}
