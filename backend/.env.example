# Copy to .env. PostgreSQL is required (see prisma/schema.prisma).
#
# Local Docker (matches backend/docker-compose.yml):
#   bun run db:prepare
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/ordostage?schema=public"

BETTER_AUTH_SECRET="generate-a-long-random-string"
BACKEND_URL="http://localhost:3000"

# Production: must be the public SPA origin (password reset links). Example:
# FRONTEND_URL="https://www.ordostage.com"

# Paddle Billing (production: pdl_live_apikey_… and live_ client token)
# PADDLE_API_KEY=""
# PADDLE_WEBHOOK_SECRET=""   # Developer tools → Notifications → endpoint secret
# PADDLE_ENV="live"          # live (default) | sandbox — only for Paddle sandbox accounts
# PADDLE_PRODUCT_ID=""       # pro_… from: bun run paddle:setup-catalog
# Webhook URL: {BACKEND_URL}/api/billing/webhook
# In Paddle: Checkout → set default payment link (e.g. https://www.ordostage.com)
# Full live setup (catalog + client token + webhook): bun run paddle:setup-production
#
# Webapp (build-time): set on the frontend service / Vite env
# VITE_PADDLE_CLIENT_TOKEN=""   # Client-side token (live_…)
# VITE_PADDLE_ENV="production"  # production (default) | sandbox

# Google Maps Platform (venue address search + mileage route distance)
# GOOGLE_MAPS_API_KEY=""
