# Copy to .env. PostgreSQL is required (see prisma/schema.prisma).
#
# Local Docker (matches backend/docker-compose.yml):
#   bun run db:prepare
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/ordostage?schema=public"

BETTER_AUTH_SECRET="generate-a-long-random-string"
BACKEND_URL="http://localhost:3000"

# Production: must be the public SPA origin (password reset links). Example:
# FRONTEND_URL="https://www.ordostage.com"
