  @@index([date])
}

model TourScheduleEvent {
  id          String   @id @default(cuid())
  tourShowId  String
  tourShow    TourShow @relation(fields: [tourShowId], references: [id], onDelete: Cascade)
  kind        String
  customLabel String?
  startTime   String
  endTime     String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  timeEntries TimeEntry[]

  @@index([tourShowId, sortOrder])
}

model TourPerson {
