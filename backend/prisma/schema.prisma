  @@unique([showId, personId])
}

// —— Time tracking (worked hours, projects, tags) ——

model TimeTag {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /** Optional UI colour (#RRGGBB). When null, clients use a stable fallback by id. */
  color          String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  entryLinks     TimeEntryTag[]

  @@index([organizationId, sortOrder])
}

model TimeParentCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /** Optional UI colour (#RRGGBB). When null, clients use a stable fallback by id. */
  color          String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  projects       TimeProject[]
  events         Event[]
  tours          Tour[]

  @@index([organizationId, sortOrder])
}

model TimeProject {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /** Optional UI colour (#RRGGBB). When null, clients use a stable fallback by id. */
  color          String?
  eventId        String?
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventShowId    String?
  eventShow      EventShow?   @relation(fields: [eventShowId], references: [id], onDelete: SetNull)
  tourId         String?
  tour           Tour?        @relation(fields: [tourId], references: [id], onDelete: SetNull)
  tourShowId     String?
  tourShow       TourShow?    @relation(fields: [tourShowId], references: [id], onDelete: SetNull)
  timeParentCategoryId String?
  timeParentCategory   TimeParentCategory? @relation(fields: [timeParentCategoryId], references: [id], onDelete: SetNull)
  isArchived     Boolean      @default(false)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  entries        TimeEntry[]

  @@index([organizationId, sortOrder])
  @@index([eventId])
  @@index([eventShowId])
  @@index([tourId])
  @@index([tourShowId])
  @@index([timeParentCategoryId])
}

model TimeEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  startsAt       DateTime
  endsAt         DateTime
  kind           String
  /** work | vacation | sick | holiday  — for time-report categorisation */
  category       String       @default("work")
  eventShowJobId String?
  eventShowJob   EventShowJob? @relation(fields: [eventShowJobId], references: [id], onDelete: SetNull)
  eventId        String?
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  tourShowId     String?
  tourShow       TourShow?    @relation(fields: [tourShowId], references: [id], onDelete: SetNull)
  tourScheduleEventId String?
  tourScheduleEvent   TourScheduleEvent? @relation(fields: [tourScheduleEventId], references: [id], onDelete: SetNull)
  eventShowStaffingId String?
  eventShowStaffing   EventShowStaffing? @relation("TimeEntryEventShowStaffing", fields: [eventShowStaffingId], references: [id], onDelete: SetNull)
  internalBookingPersonId String?
  internalBookingPerson   InternalBookingPerson? @relation(fields: [internalBookingPersonId], references: [id], onDelete: SetNull)
  /** UTC calendar day (YYYY-MM-DD) for internal-booking planned slots when `internalBookingPersonId` is set. */
  internalBookingDayKey   String?
  timeProjectId  String?
  timeProject    TimeProject? @relation(fields: [timeProjectId], references: [id], onDelete: SetNull)
  note           String?
  /** True when entry is locked from edits/deletes until explicitly unlocked. */
  isLocked       Boolean      @default(false)
  /** Shared id for segments split from one logical block (overlap carve); metadata PATCH syncs across the group. */
  segmentGroupId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tagLinks       TimeEntryTag[]
  leaveTransactions LeaveTransaction[]

  @@index([organizationId, personId, startsAt])
  @@index([personId, startsAt])
  @@index([eventShowJobId])
  @@index([tourShowId])
  @@index([tourScheduleEventId])
  @@index([eventShowStaffingId])
  @@index([internalBookingPersonId])
  @@index([organizationId, category])
  @@index([organizationId, personId, segmentGroupId])
}

model TimeEntryTag {
  timeEntryId String
  timeTagId   String
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  timeTag     TimeTag   @relation(fields: [timeTagId], references: [id], onDelete: Cascade)

  @@id([timeEntryId, timeTagId])
  @@index([timeTagId])
}

model TimeTravelClaim {
