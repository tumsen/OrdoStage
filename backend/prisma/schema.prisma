model TimesheetApproval {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId         String
  person           Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  periodStart      DateTime
  periodEnd        DateTime
  status           String       @default("approved")
  approvedAt       DateTime?
  approvedByUserId String?
  reopenedAt       DateTime?
  reopenedByUserId String?
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, personId, periodStart, periodEnd])
  @@index([organizationId, personId, status])
}

/** Org-wide leave defaults (Danish ferieår, norms, feriefridage). */
model OrganizationLeavePolicy {
  id                        String       @id @default(cuid())
  organizationId            String       @unique
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  countryCode               String       @default("DK")
  vacationYearStartMonth    Int          @default(9)
  vacationYearStartDay      Int          @default(1)
  defaultVacationDaysPerYear Float       @default(25)
  defaultExtraVacationDays  Float        @default(5)
  defaultWeeklyContractHours Float       @default(37)
  /** contract_fifth | fixed */
  hoursPerVacationDayMode   String       @default("contract_fifth")
  hoursPerVacationDayFixed  Float?
  compTimeFromOvertimeEnabled Boolean    @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  personProfiles            PersonLeaveProfile[]
}

/** Per-person leave settings and norm overrides. */
model PersonLeaveProfile {
  id                        String       @id @default(cuid())
  personId                  String       @unique
  person                    Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organizationId            String
  leaveCountryCode          String       @default("DK")
  useOrgDefaults            Boolean      @default(true)
  weeklyContractHours       Float?
  monthlyContractHours      Float?
  annualContractHours       Float?
  vacationDaysPerYear       Float?
  extraVacationDaysPerYear  Float?
  /** none | active */
  sickLeaveStatus           String       @default("none")
  sickLeaveNote             String?
  organizationLeavePolicyId String?
  organizationLeavePolicy   OrganizationLeavePolicy? @relation(fields: [organizationLeavePolicyId], references: [id], onDelete: SetNull)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@index([organizationId])
}

/** Running leave balance per person, type, and vacation year. */
model LeaveBalance {
  id              String   @id @default(cuid())
  organizationId  String
  personId        String
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  vacationYearKey String
  /** vacation_earned | vacation_used | extra_vacation_used | comp_time_earned | comp_time_used | sick_days */
  balanceType     String
  /** Days for vacation types; minutes for comp_time; days for sick_days */
  amount          Float    @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([personId, vacationYearKey, balanceType])
  @@index([organizationId, personId, vacationYearKey])
}

/** Audit log for leave balance changes. */
model LeaveTransaction {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId        String
  person          Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  vacationYearKey String
  balanceType     String
  amount          Float
  /** time_entry | overtime_accrual | manual_adjustment | opening_balance | reversal */
  source          String
  timeEntryId     String?
  timeEntry       TimeEntry?   @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  periodStart     DateTime?
  periodEnd       DateTime?
  note            String?
  createdByUserId String?
  createdAt       DateTime     @default(now())

  @@index([organizationId, personId, vacationYearKey])
  @@index([timeEntryId])
  @@index([organizationId, personId, source, periodStart, periodEnd])
}

/** Budget / actual cost line for a show production (shown on production planner). */
model ProductionCostLine {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productionId   String
  production     Production   @relation(fields: [productionId], references: [id], onDelete: Cascade)
  /** labor | venue | equipment | travel | marketing | rights | contingency | revenue | other */
  category       String       @default("other")
  label          String
  plannedCents   Int          @default(0)
  actualCents    Int?
  currencyCode   String       @default("EUR")
  /** Optional calendar span for Gantt placement */
  startDate      DateTime?
  endDate        DateTime?
  notes          String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, productionId])
  @@index([organizationId, startDate])
}

/** A show being created from concept through premiere (and optionally onward to tour). */
model Production {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  /** planning | in_progress | rehearsal | tech | preview | premiered | on_tour | closed */
  status            String       @default("planning")
  planningStartDate DateTime?
  premiereDate      DateTime?
  closedAt          DateTime?
  homeVenueId       String?
  homeVenue         Venue?       @relation(fields: [homeVenueId], references: [id], onDelete: SetNull)
  leadPersonId      String?
  leadPerson        Person?      @relation("ProductionLeadPerson", fields: [leadPersonId], references: [id], onDelete: SetNull)
  /** Set when this production goes on tour with the show. */
  tourId            String?      @unique
  tour              Tour?        @relation("PrimaryProductionTour", fields: [tourId], references: [id], onDelete: SetNull)
  /** Optional link to a resident run at the home venue. */
  eventId           String?      @unique
  event             Event?       @relation("PrimaryProductionEvent", fields: [eventId], references: [id], onDelete: SetNull)
  /** One production can have many in-house runs/events. */
  events            Event[]      @relation("ProductionEvents")
  /** One production can have many tours/legs over time. */
  tours             Tour[]       @relation("ProductionTours")
  notes             String?
  actorCount        Int?
  techCount         Int?
  durationMinutes   Int?
  stageWidth        String?
  stageDepth        String?
  stageHeight       String?
  actorNames        String[]     @default([])
  techNames         String[]     @default([])
  stageSize         String?
  technicalSpecs    String?
  techRiderPdfData  Bytes?
  techRiderPdfName  String?
  documents         ProductionDocument[]
  phases            ProductionPhase[]
  costLines         ProductionCostLine[]
  people            ProductionPerson[]
  teams             ProductionTeam[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, premiereDate])
}

model ProductionDocument {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productionId   String
  production     Production   @relation(fields: [productionId], references: [id], onDelete: Cascade)
  name           String
  /** manuscript | tech_notes | image | graphic | other */
  type           String       @default("other")
  folder         String?
  sortOrder      Int          @default(0)
  filename       String
  data           Bytes
  mimeType       String       @default("application/octet-stream")
  createdAt      DateTime     @default(now())

  @@index([productionId, createdAt])
  @@index([organizationId])
}

/** Gantt bar, milestone, or deadline on a production timeline. */
model ProductionPhase {
  id               String       @id @default(cuid())
  productionId     String
  production       Production   @relation(fields: [productionId], references: [id], onDelete: Cascade)
  title            String
  /** set_build | costume | props | design | rehearsal | tech | marketing | deadline | premiere | other */
  category         String       @default("other")
  /** span = date range; milestone | deadline = single date marker */
  phaseKind        String       @default("span")
  /** planned | in_progress | done | cancelled */
  status           String       @default("planned")
  /** 0–100 completion for Gantt bar fill */
  progressPercent  Int          @default(0)
  startDate        DateTime
  endDate          DateTime?
  assigneePersonId String?
  assigneePerson   Person?      @relation("ProductionPhaseAssignee", fields: [assigneePersonId], references: [id], onDelete: SetNull)
  departmentId     String?
  department       Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /** Finish-to-start: this phase cannot start until the dependency ends. */
  dependsOnPhaseId String?
  dependsOnPhase   ProductionPhase?  @relation("ProductionPhaseDependency", fields: [dependsOnPhaseId], references: [id], onDelete: SetNull)
  dependentPhases  ProductionPhase[] @relation("ProductionPhaseDependency")
  notes            String?
  sortOrder        Int          @default(0)
  documents        ProductionPhaseDocument[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([productionId, startDate])
  @@index([productionId, sortOrder])
  @@index([dependsOnPhaseId])
}

model ProductionPhaseDocument {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phaseId        String
  phase          ProductionPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  name           String
  type           String          @default("other")
  filename       String
  data           Bytes
  mimeType       String          @default("application/octet-stream")
  createdAt      DateTime        @default(now())

  @@index([phaseId, createdAt])
  @@index([organizationId])
}

model ProductionPerson {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  personId     String
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  role         String?
  createdAt    DateTime   @default(now())

  @@unique([productionId, personId])
}

model ProductionTeam {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([productionId, departmentId])
}
