  receivesBIncome          Boolean      @default(false)
  timeProjectId            String?
  eventId                  String?
  notes                    String?
  totalAmountCents         Int          @default(0)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([organizationId, personId, tripDate])
  @@index([eventId])
  @@index([timeProjectId])
