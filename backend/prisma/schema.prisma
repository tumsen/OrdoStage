generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth tables
model User {
  id             String        @id
  name           String
  email          String        @unique
  emailVerified  Boolean       @default(false)
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessions       Session[]
  accounts       Account[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  orgRole        String        @default("member")
  isAdmin        Boolean       @default(false)
  isActive       Boolean       @default(true)
  bookingsCreated InternalBooking[] @relation("BookingCreatedBy")
  /** All organizations this account belongs to (current org is `organizationId` + matching `orgRole`). */
  organizationMemberships OrganizationMembership[]
  preferredLanguage String?
  preferredTimeFormat String?
  preferredDistanceUnit String?
  timeEntries        TimeEntry[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Theater organization
model Organization {
  id               String             @id @default(cuid())
  name             String
  defaultLanguage  String             @default("en")
  defaultTimeFormat String            @default("24h")
  defaultDistanceUnit String          @default("km")
  users            User[]
  memberships      OrganizationMembership[]
  venues           Venue[]
  events           Event[]
  people           Person[]
  calendars        Calendar[]
  internalBookings InternalBooking[]
  departments      Department[]
  tours            Tour[]
  /** New postpaid billing mode/status. */
  billingStatus    String             @default("active")
  billingDueAt     DateTime?
  billingViewOnlySince DateTime?
  /** `flex` = monthly postpaid seat curve; `fixed` = annual committed seats (Paddle subscription). */
  billingPlan      String             @default("flex")
  committedSeats   Int?
  /** Extra seats covered above commitment until temporarySeatsBoostExpiresAt (Yearly short-term pass). */
  temporarySeatsBoost Int?
  temporarySeatsBoostExpiresAt DateTime?
  annualRenewalDate DateTime?
  annualTermStartDate DateTime?
  /** Annual invoice total in cents at last Fixed purchase / renewal. */
  annualInvoiceAmountCents Int?
  paddleSubscriptionId String?
  customDiscountPercent   Int?
  customFlatRateCents     Int?
  customFlatRateMaxUsers  Int?
  /** When set, postpaid uses this per-seat monthly rate (cents) instead of the global table (legacy field name). */
  customUserDailyRateCents Int?
  /** Optional JSON for owner-admin seat calculator: tier {base,start,floor,floorAt}, yearlyDiscountPercent, yearlyDiscountApply. */
  customSeatCalculatorJson String?
  billingCurrencyCode     String             @default("USD")
  /** Feature flag: enables production planner routes/UI for this org. */
  productionPlannerEnabled Boolean           @default(false)
  /** Per-country feature modules, e.g. { "DK": { "travelAllowance": true } }. */
  countryFeatures          Json              @default("{}")
  paddleCustomerId        String?
  /** Company / invoice information (optional — used on generated PDF invoices). */
  invoiceName      String?
  invoiceStreet    String?
  invoiceNumber    String?
  invoiceZip       String?
  invoiceCity      String?
  invoiceState     String?
  invoiceCountry   String?
  invoiceVat       String?
  invoiceEmail     String?
  invoicePhone     String?
  invoiceContact   String?
  companyLogoData     Bytes?
  companyLogoMimeType String?
  companyLogoUpdatedAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  invitations      OrganizationInvitation[]
  roleDefinitions  RoleDefinition[]
  invoices         BillingInvoice[]
  usageSnapshots   BillingUsageSnapshot[]
  timeTags         TimeTag[]
  timeParentCategories TimeParentCategory[]
  timeProjects     TimeProject[]
  timeEntries      TimeEntry[]
  productions      Production[]
  productionCostLines ProductionCostLine[]
  productionPhaseDocuments ProductionPhaseDocument[]
  productionDocuments ProductionDocument[]
  timeTravelClaims TimeTravelClaim[]
  timeMileageClaims TimeMileageClaim[]
  timesheetApprovals TimesheetApproval[]
  leavePolicy        OrganizationLeavePolicy?
  leaveTransactions  LeaveTransaction[]
}

model BillingConfig {
  /** Singleton config row with id = "default". */
  id                    String   @id
  paymentDueDays         Int     @default(7)
  baseCurrencyCode       String   @default("USD")
  priceRolloverMonthKey  String?
  /** When annual billing is selected in the seat calculator, apply this percent off the monthly total (0–100). */
  yearlyDiscountPercent  Int      @default(15)
  /** Master switch: when false, annual mode does not reduce the monthly rate (still ×12 for yearly total). */
  yearlyDiscountEnabled  Boolean  @default(true)
  /** Global default seat curve JSON (same shape as Organization.customSeatCalculatorJson). When null, billing uses the flat EUR table rate. */
  defaultSeatCalculatorJson String?
  /** Days after organization creation during which unpaid invoices do not force view-only (0 = disabled). */
  billingTrialDays           Int      @default(0)
  /** Extra days after an invoice due date before overdue view-only applies (0 = due date is the cutoff). */
  billingGraceDaysAfterDue   Int      @default(0)
  /** Round Fixed annual checkout totals to nearest €10. */
  fixedAnnualRoundToTen      Boolean  @default(true)
  /** JSON: firstSeatAnnualMonthlyMajor, discountPercentMin/Max, discountCapSeats, selfServeMaxSeats. */
  fixedPlanPricingJson       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model BillingCurrencyPrice {
  currencyCode       String   @id
  /** Per-seat monthly price in cents (legacy column name `userDailyRateCents`). */
  userDailyRateCents Int
  nextMonthUserDailyRateCents Int?
  followBaseCurrency Boolean  @default(false)
  roundingMode       String   @default("nearest")
  roundingUnit       String   @default("00")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BillingUsageSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshotDate   DateTime
  /** Billable members that UTC day (legacy column name). */
  activeUsers    Int
  /** Per-seat monthly rate in cents at snapshot time (legacy column name). */
  userDailyRateCents Int
  currencyCode    String       @default("EUR")
  createdAt      DateTime @default(now())

  @@unique([organizationId, snapshotDate])
  @@index([snapshotDate])
}

model BillingInvoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodStart    DateTime
  periodEnd      DateTime
  issuedAt       DateTime     @default(now())
  dueAt          DateTime
  status         String       @default("issued") // issued | paid | overdue | cancelled
  /** flex_monthly | fixed_overage | fixed_topup */
  invoiceKind    String       @default("flex_monthly")
  subtotalCents  Int
  discountPercent Int         @default(0)
  discountCents  Int          @default(0)
  totalCents     Int
  currency       String       @default("EUR")
  paddleInvoiceId String?
  paddleTransactionId String?
  paddleInvoiceUrl String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lines          BillingInvoiceLine[]

  @@index([organizationId, status])
  @@index([issuedAt])
}

model BillingInvoiceLine {
  id             String         @id @default(cuid())
  invoiceId      String
  invoice        BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId         String?
  userName       String?
  userEmail      String?
  daysConsumed   Int
  rateCents      Int
  subtotalCents  Int
  createdAt      DateTime @default(now())
}

/** User membership in an organization (role is per org). `User.organizationId` is the active workspace. */
model OrganizationMembership {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgRole          String       @default("member")
  createdAt        DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

/** Per-organization role: `slug` matches `User.orgRole` for assigned members. */
model RoleDefinition {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  description    String?
  /** Nav / areas this role can see. */
  views          String[] @default([])
  /** What this role can do (create, manage, billing, etc.). */
  actions        String[] @default([])
  sortOrder      Int      @default(0)
  /** System: only `owner` and `admin` groups are protected. */
  isSystem       Boolean  @default(false)
  people         Person[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model OrganizationInvitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  orgRole        String
  token          String       @unique @default(cuid())
  invitedById    String?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?

  @@index([organizationId, email])
}

// App models - all scoped to an organization
model Venue {
  id               String             @id @default(cuid())
  name             String
  addressStreet    String?
  addressNumber    String?
  addressZip       String?
  addressCity      String?
  addressState     String?
  addressCountry   String?
  capacity         Int?
  width              String?
  length             String?
  height             String?
  contactPersonName  String?
  contactPersonEmail String?
  contactPersonPhone String?
  contactPersonRole  String?
  contactCompanyName String?
  contactCompanyVat  String?
  customFields       String?
  notes              String?
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events           Event[]
  internalBookings InternalBooking[]
  eventShows       EventShow[]
  eventShowJobs    EventShowJob[]
  documents        VenueDocument[]
  productions      Production[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model VenueDocument {
  id        String   @id @default(cuid())
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name      String
  /** drawing | image | document | other */
  kind      String   @default("other")
  filename  String
  data      Bytes
  mimeType  String   @default("application/octet-stream")
  createdAt DateTime @default(now())

  @@index([venueId])
}

model Person {
  id               String                  @id @default(cuid())
  name             String
  role             String?
  email            String?
  phone                 String?
  addressStreet         String?
  addressNumber         String?
  addressZip            String?
  addressCity           String?
  addressState          String?
  addressCountry        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes            String?
  photoData         Bytes?
  photoFilename     String?
  photoMimeType     String?
  photoUpdatedAt    DateTime?
  photoFocusX       Int        @default(50)
  photoFocusY       Int        @default(50)
  /** Crop scale as percent of cover-fit (100–400). */
  photoZoom         Int        @default(100)
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId     String?
  department       Department?             @relation(fields: [departmentId], references: [id])
  documents        PersonDocument[]
  documentPermissions PersonDocumentAllowedPerson[]
  teamMemberships  PersonTeam[]
  assignments      EventPerson[]
  internalBookings InternalBookingPerson[]
  tourAssignments  TourPerson[]
  showAssignments  TourShowPerson[]
  tourNotes        TourPersonNote[]
  responsibleShows EventShow[]              @relation("EventShowResponsible")
  showStaffing     EventShowStaffing[]      @relation("EventShowStaffingPerson")
  showJobs         EventShowJob[]
  eventShowJobAssignments EventShowJobPerson[] @relation("EventShowJobPersonAssignee")
  eventsAsLead            Event[]                  @relation("EventLeadPerson")
  /** App access for users linked by email uses this permission group (RoleDefinition). */
  permissionGroupId String?
  permissionGroup   RoleDefinition?        @relation(fields: [permissionGroupId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  isActive         Boolean                 @default(true)
  /** Cast/crew: in-house vs contractor — required for new people; existing rows default to internal. */
  affiliation      String                  @default("internal")
  /** Expected work hours per week — used in reports to compute overtime. */
  weeklyContractHours Float?
  /** Yearly vacation day allowance (e.g. 25 days in Denmark). */
  vacationDaysPerYear Float?
  /** When a manager last sent the app login / password-setup email (manual action only). */
  appLoginEmailSentAt DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  timeEntries      TimeEntry[]
  timeTravelClaims TimeTravelClaim[]
  timeMileageClaims TimeMileageClaim[]
  timesheetApprovals TimesheetApproval[]
  productionsLed     Production[]            @relation("ProductionLeadPerson")
  productionPhases   ProductionPhase[]       @relation("ProductionPhaseAssignee")
  productionAssignments ProductionPerson[]
  leaveProfile       PersonLeaveProfile?
  leaveBalances      LeaveBalance[]
  leaveTransactions  LeaveTransaction[]
}

model PersonDocument {
  id         String   @id @default(cuid())
  personId   String
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  name       String
  type       String   @default("other")
  filename   String
  data       Bytes
  mimeType   String   @default("application/octet-stream")
  /** When the document is considered expired (e.g. passport); null = no specific date. */
  expiresAt  DateTime?
  /** Explicit “never expires” (badge shows ∞); implies no expiresAt. */
  doesNotExpire Boolean @default(false)
  allowedTeams PersonDocumentAllowedTeam[]
  allowedPeople PersonDocumentAllowedPerson[]
  createdAt  DateTime @default(now())
}

model PersonDocumentAllowedTeam {
  id         String         @id @default(cuid())
  documentId String
  teamId     String
  document   PersonDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  team       Department     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([documentId, teamId])
  @@index([teamId])
}

model PersonDocumentAllowedPerson {
  id             String         @id @default(cuid())
  documentId     String
  allowedPersonId String
  document       PersonDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  allowedPerson  Person         @relation(fields: [allowedPersonId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([documentId, allowedPersonId])
  @@index([allowedPersonId])
}

model Event {
  id             String        @id @default(cuid())
  title          String
  description    String?
  /** Set when the event has a known window; events with no shows may leave this null. */
  startDate      DateTime?
  endDate        DateTime?
  status         String        @default("draft")
  venueId        String?
  venue          Venue?        @relation(fields: [venueId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         EventPerson[]
  documents      Document[]
  tags           String?
  contactPerson  String?
  getInTime      String?
  setupTime      String?
  stageSize      String?
  actorCount     Int?
  allergies      String?
  customFields   String?
  ownerTeamId    String?
  ownerTeam      Department?   @relation("EventOwnerTeam", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  /** Overall event lead (coordination role; does not count as a job assignment). */
  leadPersonId   String?
  leadPerson     Person?       @relation("EventLeadPerson", fields: [leadPersonId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  shows          EventShow[]
  teams          EventTeam[]
  teamNotes      EventTeamNote[]
  teamDocuments  EventTeamDocument[]
  timeProjects   TimeProject[]
  timeEntries    TimeEntry[]
  bookings       InternalBooking[]
  /** Legacy single linked production record (kept for backward compatibility). */
  production     Production?   @relation("PrimaryProductionEvent")
  /** Optional parent show/production; enables one production to own many in-house runs. */
  productionId   String?
  productionRef  Production?   @relation("ProductionEvents", fields: [productionId], references: [id], onDelete: SetNull)
  timeParentCategoryId String?
  timeParentCategory   TimeParentCategory? @relation(fields: [timeParentCategoryId], references: [id], onDelete: SetNull)

  @@index([ownerTeamId])
  @@index([organizationId, startDate])
  @@index([productionId])
  @@index([timeParentCategoryId])
}

model EventTeam {
  id          String     @id @default(cuid())
  eventId     String
  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId      String
  team        Department @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isOwner     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  notesFrom   EventTeamNote[] @relation("EventTeamNoteFromTeam")
  notesTo     EventTeamNote[] @relation("EventTeamNoteToTeam")
  documents   EventTeamDocument[]

  @@unique([eventId, teamId])
  @@index([teamId])
}

model EventTeamNote {
  id              String     @id @default(cuid())
  eventId         String
  event           Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fromTeamId      String
  fromTeam        EventTeam  @relation("EventTeamNoteFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeamId        String
  toTeam          EventTeam  @relation("EventTeamNoteToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)
  body            String
  createdByUserId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([eventId, createdAt])
  @@index([fromTeamId])
  @@index([toTeamId])
}

model EventTeamDocument {
  id             String    @id @default(cuid())
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId         String
  team           EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name           String
  type           String    @default("other")
  filename       String
  data           Bytes
  mimeType       String    @default("application/octet-stream")
  createdByUserId String?
  createdAt      DateTime  @default(now())

  @@index([eventId, teamId, createdAt])
}

model EventPerson {
  id       String  @id @default(cuid())
  eventId  String
  personId String
  role     String?
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person   Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([eventId, personId])
}

model EventShow {
  id                   String       @id @default(cuid())
  eventId              String
  event                Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timeProjects         TimeProject[]
  showDate             DateTime
  showTime             String
  durationMinutes      Int
  venueId              String
  venue                Venue        @relation(fields: [venueId], references: [id])
  technicalNotes       String?
  fohNotes             String?
  ticketNotes          String?
  hospitalityNotes     String?
  teamResponsibleId    String?
  teamResponsible      Person?      @relation("EventShowResponsible", fields: [teamResponsibleId], references: [id], onDelete: SetNull)
  getInTime            String?
  getInDurationMinutes Int?
  getOutTime           String?
  getOutDurationMinutes Int?
  rehearsalTime        String?
  rehearsalDurationMinutes Int?
  soundcheckTime       String?
  soundcheckDurationMinutes Int?
  breakTime            String?
  breakDurationMinutes Int?
  notes                String?
  /** draft | confirmed | cancelled — primary confirmation is per show; Event.status is a rollup. */
  status               String       @default("draft")
  /** departmentId -> staffing signed-off for this show */
  staffingOkByDepartment Json?
  /** Tickets offered for sale for this performance (optional manual count). */
  ticketsOnSale        Int?
  /** Tickets sold so far (optional manual count). */
  soldTickets          Int?
  /** When `soldTickets` was last updated (set server-side on sale count changes). */
  soldTicketsRecordedAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  staffing             EventShowStaffing[]
  jobs                 EventShowJob[]

  @@index([eventId, showDate])
  @@index([venueId, showDate])
}

/** Per-show work item: title, when/where, optional assignee. Replaces fixed slots (get-in, rehearsal, …) in the UI. */
model EventShowJob {
  id              String    @id @default(cuid())
  showId          String
  show            EventShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  title           String
  jobDate         DateTime
  startTime       String
  durationMinutes Int
  venueId         String
  venue           Venue     @relation(fields: [venueId], references: [id])
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  personId        String?
  person          Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)
  /** How many people are required for this job (drives assignment slot count in UI). */
  peopleNeeded    Int       @default(1)
  assignments     EventShowJobPerson[]
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  timeEntries     TimeEntry[]

  @@index([showId, sortOrder])
  @@index([venueId])
  @@index([departmentId])
}

model EventShowJobPerson {
  id        String       @id @default(cuid())
  jobId     String
  job       EventShowJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  personId  String
  person    Person       @relation("EventShowJobPersonAssignee", fields: [personId], references: [id], onDelete: Cascade)
  slotIndex Int          @default(0)
  createdAt DateTime     @default(now())

  @@unique([jobId, personId])
  @@unique([jobId, slotIndex])
  @@index([personId])
}

model EventShowStaffing {
  id                     String    @id @default(cuid())
  showId                 String
  show                   EventShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  personId               String
  person                 Person    @relation("EventShowStaffingPerson", fields: [personId], references: [id], onDelete: Cascade)
  departmentId           String?
  department             Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  isLead                 Boolean   @default(false)
  role                   String?
  meetingTime            String?
  meetingDurationMinutes Int?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  timeEntries            TimeEntry[] @relation("TimeEntryEventShowStaffing")

  @@unique([showId, personId])
  @@index([personId])
  @@index([departmentId])
  @@index([showId, departmentId, isLead])
}

model Document {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  type      String   @default("other")
  filename  String
  data      Bytes
  mimeType  String   @default("application/pdf")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Calendar {
  id             String       @id @default(cuid())
  name           String
  token          String       @unique @default(cuid())
  filter         String?
  /** IANA zone for interpreting show/tour date + time in public ICS (matches in-app wall clock). */
  icsWallClockZone String     @default("UTC")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SiteContent {
  key       String
  locale    String   @default("en")
  value     String
  updatedAt DateTime @updatedAt

  @@id([key, locale])
}

model InternalBooking {
  id             String                  @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  type           String                  @default("other") // rehearsal | maintenance | private | venue_booking | other
  venueId        String?
  venue          Venue?                  @relation(fields: [venueId], references: [id])
  /** Optional event link: when set, this booking is part of the event's venue occupation. */
  eventId        String?
  event          Event?                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /** When true the booking can't be moved/edited/deleted until unlocked. */
  isLocked       Boolean                 @default(false)
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?                   @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  people         InternalBookingPerson[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([eventId])
  @@index([venueId, startDate])
  @@index([organizationId, startDate])
}

model InternalBookingPerson {
  id        String          @id @default(cuid())
  bookingId String
  personId  String
  role      String?
  booking   InternalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  person    Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@unique([bookingId, personId])
}

model Department {
  id             String       @id @default(cuid())
  name           String
  color          String       @default("#6366f1")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         Person[]
  teamMembers    PersonTeam[]
  documentPermissions PersonDocumentAllowedTeam[]
  tourAssignments TourTeam[]
  ownerEvents    Event[]      @relation("EventOwnerTeam")
  eventTeams     EventTeam[]
  showJobs       EventShowJob[]
  showStaffing   EventShowStaffing[]
  productionPhases ProductionPhase[]
  productionTeams  ProductionTeam[]
  createdAt      DateTime     @default(now())
}

model PersonTeam {
  id           String     @id @default(cuid())
  personId     String
  departmentId String
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role         String?
  createdAt    DateTime   @default(now())

  @@unique([personId, departmentId])
}

model Tour {
  id               String       @id @default(cuid())
  shareToken        String       @unique @default(cuid())
  name             String
  description      String?
  status           String       @default("draft") // draft | active | completed
  tourManagerName  String?
  tourManagerPhone String?
  tourManagerEmail String?
  notes                String?
  showDuration         String?   // e.g. "1h 45min" — duration of the show
  handsNeeded          Int?      // number of stagehands/crew needed at venue
  stageRequirements    String?   // stage setup requirements
  soundRequirements    String?   // PA/sound system requirements
  lightingRequirements String?   // lighting requirements
  riderNotes           String?   // additional tech rider notes
  customFields         String?   // JSON array of key/value pairs
  riderVisibility      String?   // JSON toggle map for what to include in rider
  techRiderPdfData     Bytes?    // uploaded static tech rider PDF bytes
  techRiderPdfName     String?   // original filename
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shows            TourShow[]
  timeProjects     TimeProject[]
  people           TourPerson[]
  teams            TourTeam[]
  personNotes      TourPersonNote[]
  /** Legacy single linked production record (kept for backward compatibility). */
  production       Production? @relation("PrimaryProductionTour")
  /** Optional parent show/production; enables one production to own many tours/legs. */
  productionId     String?
  productionRef    Production? @relation("ProductionTours", fields: [productionId], references: [id], onDelete: SetNull)
  timeParentCategoryId String?
  timeParentCategory   TimeParentCategory? @relation(fields: [timeParentCategoryId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([productionId])
  @@index([timeParentCategoryId])
}

model TourTeam {
  id           String     @id @default(cuid())
  tourId       String
  departmentId String
  tour         Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([tourId, departmentId])
}

model TourShow {
  id             String   @id @default(cuid())
  tourId         String
  tour           Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  timeProjects   TimeProject[]
  date           DateTime
  /// Calendar day key YYYY-MM-DD (UTC) — one TourShow row per tour per day.
  dayKey         String
  type           String   @default("show")  // show | travel | day_off
  fromLocation   String?
  toLocation     String?
  showTime       String?
  getInTime      String?
  rehearsalTime  String?
  soundcheckTime String?
  doorsTime      String?
  venueName      String?
  venueStreet    String?
  venueNumber    String?
  venueZip       String?
  venueCity      String?
  venueState     String?
  venueCountry   String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  hotelName      String?
  hotelStreet    String?
  hotelNumber    String?
  hotelZip       String?
  hotelCity      String?
  hotelState     String?
  hotelCountry   String?
  hotelPhone     String?
  hotelCheckIn   String?
  hotelCheckOut  String?
  travelInfo     String?
  cateringInfo   String?
  notes          String?
  order          Int      @default(0)
  handsNeeded    Int?     // per-venue override for number of hands needed
  travelTimeMinutes Int?  // estimated drive/travel time to NEXT venue in minutes
  distanceKm        Float? // estimated distance to NEXT venue in km
  techRiderSentAt   DateTime?
  techRiderSentTo   String?
  techRiderOpenedAt DateTime?
  techRiderOpenCount Int @default(0)
  techRiderLastOpenedAt DateTime?
