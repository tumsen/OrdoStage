  personId                 String
  person                   Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdByUserId          String?
  tripDate                 DateTime
  fromPlace                String
  toPlace                  String
  purpose                  String       @default("")
  country                  String       @default("DK")
  vehicleType              String       @default("car")
  distanceKm               Float
  rateYear                 Int          @default(2026)
  rateCentsPerKmHigh       Int          @default(394)
  rateCentsPerKmLow        Int          @default(228)
  bicycleRateCentsPerKm    Int          @default(64)
  highRateKm               Float        @default(0)
  lowRateKm                Float        @default(0)
