generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth tables
model User {
  id             String        @id
  name           String
  email          String        @unique
  emailVerified  Boolean       @default(false)
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessions       Session[]
  accounts       Account[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  orgRole        String        @default("member")
  isAdmin        Boolean       @default(false)
  isActive       Boolean       @default(true)
  bookingsCreated InternalBooking[] @relation("BookingCreatedBy")
  /** All organizations this account belongs to (current org is `organizationId` + matching `orgRole`). */
  organizationMemberships OrganizationMembership[]
  preferredLanguage String?
  preferredTimeFormat String?
  preferredDistanceUnit String?
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Theater organization
model Organization {
  id               String             @id @default(cuid())
  name             String
  defaultLanguage  String             @default("en")
  defaultTimeFormat String            @default("24h")
  defaultDistanceUnit String          @default("km")
  users            User[]
  memberships      OrganizationMembership[]
  venues           Venue[]
  events           Event[]
  people           Person[]
  calendars        Calendar[]
  internalBookings InternalBooking[]
  departments      Department[]
  tours            Tour[]
  /** New postpaid billing mode/status. */
  billingStatus    String             @default("active")
  billingDueAt     DateTime?
  billingViewOnlySince DateTime?
  customUserDailyRateCents Int?
  customDiscountPercent   Int?
  customFlatRateCents     Int?
  customFlatRateMaxUsers  Int?
  /** Company / invoice information (optional — used on generated PDF invoices). */
  invoiceName      String?
  invoiceStreet    String?
  invoiceNumber    String?
  invoiceZip       String?
  invoiceCity      String?
  invoiceState     String?
  invoiceCountry   String?
  invoiceVat       String?
  invoiceEmail     String?
  invoicePhone     String?
  invoiceContact   String?
  companyLogoData     Bytes?
  companyLogoMimeType String?
  companyLogoUpdatedAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  invitations      OrganizationInvitation[]
  roleDefinitions  RoleDefinition[]
  invoices         BillingInvoice[]
  usageSnapshots   BillingUsageSnapshot[]
}

model BillingConfig {
  /** Singleton config row with id = "default". */
  id                    String   @id
  defaultUserDailyRateCents Int  @default(1500)
  defaultDiscountPercent Int    @default(0)
  defaultFlatRateCents   Int?
  defaultFlatRateMaxUsers Int?
  paymentDueDays         Int     @default(7)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model BillingUsageSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshotDate   DateTime
  activeUsers    Int
  userDailyRateCents Int
  createdAt      DateTime @default(now())

  @@unique([organizationId, snapshotDate])
  @@index([snapshotDate])
}

model BillingInvoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodStart    DateTime
  periodEnd      DateTime
  issuedAt       DateTime     @default(now())
  dueAt          DateTime
  status         String       @default("issued") // issued | paid | overdue | cancelled
  subtotalCents  Int
  discountPercent Int         @default(0)
  discountCents  Int          @default(0)
  totalCents     Int
  currency       String       @default("EUR")
  paddleInvoiceId String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lines          BillingInvoiceLine[]

  @@index([organizationId, status])
  @@index([issuedAt])
}

model BillingInvoiceLine {
  id             String         @id @default(cuid())
  invoiceId      String
  invoice        BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId         String?
  userName       String?
  userEmail      String?
  daysConsumed   Int
  rateCents      Int
  subtotalCents  Int
  createdAt      DateTime @default(now())
}

/** User membership in an organization (role is per org). `User.organizationId` is the active workspace. */
model OrganizationMembership {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgRole          String       @default("member")
  createdAt        DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

/** Per-organization role: `slug` matches `User.orgRole` for assigned members. */
model RoleDefinition {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  description    String?
  /** Nav / areas this role can see. */
  views          String[] @default([])
  /** What this role can do (create, manage, billing, etc.). */
  actions        String[] @default([])
  sortOrder      Int      @default(0)
  /** System: only `owner` and `admin` groups are protected. */
  isSystem       Boolean  @default(false)
  people         Person[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model OrganizationInvitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  orgRole        String
  token          String       @unique @default(cuid())
  invitedById    String?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?

  @@index([organizationId, email])
}

// App models - all scoped to an organization
model Venue {
  id               String             @id @default(cuid())
  name             String
  addressStreet    String?
  addressNumber    String?
  addressZip       String?
  addressCity      String?
  addressState     String?
  addressCountry   String?
  capacity         Int?
  width            String?
  length           String?
  height           String?
  customFields     String?
  notes            String?
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events           Event[]
  internalBookings InternalBooking[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Person {
  id               String                  @id @default(cuid())
  name             String
  role             String?
  email            String?
  phone                 String?
  addressStreet         String?
  addressNumber         String?
  addressZip            String?
  addressCity           String?
  addressState          String?
  addressCountry        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes            String?
  photoData         Bytes?
  photoFilename     String?
  photoMimeType     String?
  photoUpdatedAt    DateTime?
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId     String?
  department       Department?             @relation(fields: [departmentId], references: [id])
  documents        PersonDocument[]
  documentPermissions PersonDocumentAllowedPerson[]
  teamMemberships  PersonTeam[]
  assignments      EventPerson[]
  internalBookings InternalBookingPerson[]
  tourAssignments  TourPerson[]
  showAssignments  TourShowPerson[]
  tourNotes        TourPersonNote[]
  /** App access for users linked by email uses this permission group (RoleDefinition). */
  permissionGroupId String?
  permissionGroup   RoleDefinition?        @relation(fields: [permissionGroupId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  isActive         Boolean                 @default(true)
  /** Cast/crew: in-house vs contractor — required for new people; existing rows default to internal. */
  affiliation      String                  @default("internal")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model PersonDocument {
  id         String   @id @default(cuid())
  personId   String
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  name       String
  type       String   @default("other")
  filename   String
  data       Bytes
  mimeType   String   @default("application/octet-stream")
  /** When the document is considered expired (e.g. passport); null = no specific date. */
  expiresAt  DateTime?
  /** Explicit “never expires” (badge shows ∞); implies no expiresAt. */
  doesNotExpire Boolean @default(false)
  allowedTeams PersonDocumentAllowedTeam[]
  allowedPeople PersonDocumentAllowedPerson[]
  createdAt  DateTime @default(now())
}

model PersonDocumentAllowedTeam {
  id         String         @id @default(cuid())
  documentId String
  teamId     String
  document   PersonDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  team       Department     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([documentId, teamId])
  @@index([teamId])
}

model PersonDocumentAllowedPerson {
  id             String         @id @default(cuid())
  documentId     String
  allowedPersonId String
  document       PersonDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  allowedPerson  Person         @relation(fields: [allowedPersonId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([documentId, allowedPersonId])
  @@index([allowedPersonId])
}

model Event {
  id             String        @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  status         String        @default("draft")
  venueId        String?
  venue          Venue?        @relation(fields: [venueId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         EventPerson[]
  documents      Document[]
  tags           String?
  contactPerson  String?
  getInTime      String?
  setupTime      String?
  stageSize      String?
  actorCount     Int?
  allergies      String?
  customFields   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model EventPerson {
  id       String  @id @default(cuid())
  eventId  String
  personId String
  role     String?
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person   Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([eventId, personId])
}

model Document {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  type      String   @default("other")
  filename  String
  data      Bytes
  mimeType  String   @default("application/pdf")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Calendar {
  id             String       @id @default(cuid())
  name           String
  token          String       @unique @default(cuid())
  filter         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SiteContent {
  key       String
  locale    String   @default("en")
  value     String
  updatedAt DateTime @updatedAt

  @@id([key, locale])
}

model InternalBooking {
  id             String                  @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  type           String                  @default("other") // rehearsal | maintenance | private | other
  venueId        String?
  venue          Venue?                  @relation(fields: [venueId], references: [id])
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?                   @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  people         InternalBookingPerson[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model InternalBookingPerson {
  id        String          @id @default(cuid())
  bookingId String
  personId  String
  role      String?
  booking   InternalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  person    Person          @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([bookingId, personId])
}

model Department {
  id             String       @id @default(cuid())
  name           String
  color          String       @default("#6366f1")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         Person[]
  teamMembers    PersonTeam[]
  documentPermissions PersonDocumentAllowedTeam[]
  tourAssignments TourTeam[]
  createdAt      DateTime     @default(now())
}

model PersonTeam {
  id           String     @id @default(cuid())
  personId     String
  departmentId String
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role         String?
  createdAt    DateTime   @default(now())

  @@unique([personId, departmentId])
}

model Tour {
  id               String       @id @default(cuid())
  shareToken        String       @unique @default(cuid())
  name             String
  description      String?
  status           String       @default("draft") // draft | active | completed
  tourManagerName  String?
  tourManagerPhone String?
  tourManagerEmail String?
  notes                String?
  showDuration         String?   // e.g. "1h 45min" — duration of the show
  handsNeeded          Int?      // number of stagehands/crew needed at venue
  stageRequirements    String?   // stage setup requirements
  soundRequirements    String?   // PA/sound system requirements
  lightingRequirements String?   // lighting requirements
  riderNotes           String?   // additional tech rider notes
  customFields         String?   // JSON array of key/value pairs
  riderVisibility      String?   // JSON toggle map for what to include in rider
  techRiderPdfData     Bytes?    // uploaded static tech rider PDF bytes
  techRiderPdfName     String?   // original filename
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shows            TourShow[]
  people           TourPerson[]
  teams            TourTeam[]
  personNotes      TourPersonNote[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model TourTeam {
  id           String     @id @default(cuid())
  tourId       String
  departmentId String
  tour         Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([tourId, departmentId])
}

model TourShow {
  id             String   @id @default(cuid())
  tourId         String
  tour           Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  date           DateTime
  type           String   @default("show")  // show | travel | day_off
  fromLocation   String?
  toLocation     String?
  showTime       String?
  getInTime      String?
  rehearsalTime  String?
  soundcheckTime String?
  doorsTime      String?
  venueName      String?
  venueStreet    String?
  venueNumber    String?
  venueZip       String?
  venueCity      String?
  venueState     String?
  venueCountry   String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  hotelName      String?
  hotelStreet    String?
  hotelNumber    String?
  hotelZip       String?
  hotelCity      String?
  hotelState     String?
  hotelCountry   String?
  hotelPhone     String?
  hotelCheckIn   String?
  hotelCheckOut  String?
  travelInfo     String?
  cateringInfo   String?
  notes          String?
  order          Int      @default(0)
  handsNeeded    Int?     // per-venue override for number of hands needed
  travelTimeMinutes Int?  // estimated drive/travel time to NEXT venue in minutes
  distanceKm        Float? // estimated distance to NEXT venue in km
  techRiderSentAt   DateTime?
  techRiderSentTo   String?
  techRiderOpenedAt DateTime?
  techRiderOpenCount Int @default(0)
  techRiderLastOpenedAt DateTime?
  techRiderPdfUrl   String?
  showPeople     TourShowPerson[]
  personNotes    TourPersonNote[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TourPerson {
  id            String  @id @default(cuid())
  tourId        String
  tour          Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  personId      String
  person        Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  role          String?
  personalToken String  @unique @default(cuid())

  @@unique([tourId, personId])
}

model TourPersonNote {
  id         String   @id @default(cuid())
  tourId     String
  showId     String
  personId   String
  note       String?
  needsHotel Boolean  @default(false)
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  show       TourShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([showId, personId])
}

model TourShowPerson {
  id       String   @id @default(cuid())
  showId   String
  show     TourShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  personId String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  role     String?

  @@unique([showId, personId])
}
