generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Better Auth tables
model User {
  id             String        @id
  name           String
  email          String        @unique
  emailVerified  Boolean       @default(false)
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessions       Session[]
  accounts       Account[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  orgRole        String        @default("member")
  isAdmin        Boolean       @default(false)
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Theater organization
model Organization {
  id               String             @id @default(cuid())
  name             String
  creditBalance    Int                @default(0)
  lastDeductedAt   DateTime           @default(now())
  users            User[]
  venues           Venue[]
  events           Event[]
  people           Person[]
  calendars        Calendar[]
  creditPurchases  CreditPurchase[]
  creditLogs       CreditLog[]
  internalBookings InternalBooking[]
  departments      Department[]
  tours            Tour[]
  freeTrialUsed    Boolean            @default(false)
  unlimitedCredits Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model CreditPurchase {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  days            Int
  amountCents     Int
  stripeSessionId String?      @unique
  createdAt       DateTime     @default(now())
}

// App models - all scoped to an organization
model Venue {
  id               String             @id @default(cuid())
  name             String
  address          String?
  capacity         Int?
  notes            String?
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events           Event[]
  internalBookings InternalBooking[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Person {
  id               String                  @id @default(cuid())
  name             String
  role             String?
  email            String?
  phone                 String?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId     String?
  department       Department?             @relation(fields: [departmentId], references: [id])
  assignments      EventPerson[]
  internalBookings InternalBookingPerson[]
  tourAssignments  TourPerson[]
  showAssignments  TourShowPerson[]
  tourNotes        TourPersonNote[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model Event {
  id             String        @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  status         String        @default("draft")
  venueId        String?
  venue          Venue?        @relation(fields: [venueId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         EventPerson[]
  documents      Document[]
  tags           String?
  contactPerson  String?
  getInTime      String?
  setupTime      String?
  stageSize      String?
  actorCount     Int?
  allergies      String?
  customFields   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model EventPerson {
  id       String  @id @default(cuid())
  eventId  String
  personId String
  role     String?
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person   Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([eventId, personId])
}

model Document {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  type      String   @default("other")
  filename  String
  data      Bytes
  mimeType  String   @default("application/pdf")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Calendar {
  id             String       @id @default(cuid())
  name           String
  token          String       @unique @default(cuid())
  filter         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Tracks all credit changes for audit trail
model CreditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  delta          Int
  reason         String
  note           String?
  adminUserId    String?
  createdAt      DateTime     @default(now())
}

// Configurable day pack prices
model PricePack {
  id          String  @id @default(cuid())
  packId      String  @unique
  days        Int
  amountCents Int
  label       String
  active      Boolean @default(true)
}

model InternalBooking {
  id             String                  @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  type           String                  @default("other") // rehearsal | maintenance | private | other
  venueId        String?
  venue          Venue?                  @relation(fields: [venueId], references: [id])
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         InternalBookingPerson[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model InternalBookingPerson {
  id        String          @id @default(cuid())
  bookingId String
  personId  String
  role      String?
  booking   InternalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  person    Person          @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([bookingId, personId])
}

model Department {
  id             String       @id @default(cuid())
  name           String
  color          String       @default("#6366f1")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people         Person[]
  createdAt      DateTime     @default(now())
}

model Tour {
  id               String       @id @default(cuid())
  shareToken        String       @unique @default(cuid())
  name             String
  description      String?
  status           String       @default("draft") // draft | active | completed
  tourManagerName  String?
  tourManagerPhone String?
  tourManagerEmail String?
  notes                String?
  showDuration         String?   // e.g. "1h 45min" — duration of the show
  handsNeeded          Int?      // number of stagehands/crew needed at venue
  stageRequirements    String?   // stage setup requirements
  soundRequirements    String?   // PA/sound system requirements
  lightingRequirements String?   // lighting requirements
  riderNotes           String?   // additional tech rider notes
  techRiderPdfData     Bytes?    // uploaded static tech rider PDF bytes
  techRiderPdfName     String?   // original filename
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shows            TourShow[]
  people           TourPerson[]
  personNotes      TourPersonNote[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model TourShow {
  id             String   @id @default(cuid())
  tourId         String
  tour           Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  date           DateTime
  type           String   @default("show")  // show | travel | day_off
  fromLocation   String?
  toLocation     String?
  showTime       String?
  getInTime      String?
  rehearsalTime  String?
  soundcheckTime String?
  doorsTime      String?
  venueName      String?
  venueAddress   String?
  venueCity      String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  hotelName      String?
  hotelAddress   String?
  hotelPhone     String?
  hotelCheckIn   String?
  hotelCheckOut  String?
  travelInfo     String?
  cateringInfo   String?
  notes          String?
  order          Int      @default(0)
  handsNeeded    Int?     // per-venue override for number of hands needed
  travelTimeMinutes Int?  // estimated drive/travel time to NEXT venue in minutes
  distanceKm        Float? // estimated distance to NEXT venue in km
  techRiderSentAt   DateTime?
  techRiderSentTo   String?
  techRiderOpenedAt DateTime?
  techRiderOpenCount Int @default(0)
  techRiderLastOpenedAt DateTime?
  techRiderPdfUrl   String?
  showPeople     TourShowPerson[]
  personNotes    TourPersonNote[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TourPerson {
  id            String  @id @default(cuid())
  tourId        String
  tour          Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  personId      String
  person        Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  role          String?
  personalToken String  @unique @default(cuid())

  @@unique([tourId, personId])
}

model TourPersonNote {
  id         String   @id @default(cuid())
  tourId     String
  showId     String
  personId   String
  note       String?
  needsHotel Boolean  @default(false)
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  show       TourShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([showId, personId])
}

model TourShowPerson {
  id       String   @id @default(cuid())
  showId   String
  show     TourShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  personId String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  role     String?

  @@unique([showId, personId])
}
